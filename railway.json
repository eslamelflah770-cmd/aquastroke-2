{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "npm run build --workspace=@aquastroke/web"
  },
  "deploy": {
    "startCommand": "npm run preview --workspace=@aquastroke/web",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  }
}
